# Archivo de referencia para configurar el sitio estático mediante Render Blueprint.
# No contiene secretos. Ajusta el nombre si decides importar el Blueprint.
services:
  - type: web
    runtime: static
    name: emmagina-frontend
    buildCommand: node scripts/generar-sitemap.js || echo "Static site ready"
    staticPublishPath: .
    routes:
      # Rutas SEO prerenderizadas por el backend para compartir productos y sitemap dinámico.
      # Ajusta el dominio si tu backend tiene otro nombre en Render.
      - type: rewrite
        source: /producto/*
        destination: https://emmagina-backend.onrender.com/producto/*
      - type: rewrite
        source: /p/*
        destination: https://emmagina-backend.onrender.com/p/*
      - type: rewrite
        source: /sitemap.xml
        destination: https://emmagina-backend.onrender.com/sitemap.xml
      - type: rewrite
        source: /robots.txt
        destination: https://emmagina-backend.onrender.com/robots.txt
    headers:
      - path: /*
        name: Content-Security-Policy
        value: "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; frame-src 'none'; form-action 'self'; script-src 'self'; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; connect-src 'self' https://emmagina-backend.onrender.com https://res.cloudinary.com https://*.cloudinary.com; media-src 'self' blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
      - path: /*
        name: X-Content-Type-Options
        value: nosniff
      - path: /*
        name: Referrer-Policy
        value: strict-origin-when-cross-origin
      - path: /*
        name: Permissions-Policy
        value: camera=(), microphone=(), geolocation=(), payment=()
      - path: /*
        name: X-Frame-Options
        value: DENY
      - path: /admin/*
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /admin/*
        name: Cache-Control
        value: no-store, max-age=0, must-revalidate

      - path: /acceso.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /cuenta.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /pedido.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /pago.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /carrito.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /finalizar-compra.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /seguimiento-pedido.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
      - path: /pagina.html
        name: X-Robots-Tag
        value: noindex, nofollow, noarchive
